# CaddyUI base URL (its /api/v1 REST API lives under this host).
CADDYUI_URL=https://caddyui.strant.casa

# CaddyUI API token. Mint one in the CaddyUI UI at /api-tokens (shown once).
# Scope: `full` for all CRUD, `proxy_write` for proxy hosts only, `read_only` for reads.
# Sent as `Authorization: Bearer <token>`. Never commit the real value.
CADDYUI_TOKEN=

# Optional: HTTP port for the web (Streamable HTTP) entrypoint (default 8080).
# MCP_HTTP_PORT=8080

# Optional log level (DEBUG, INFO, WARNING, ERROR).
# LOG_LEVEL=INFO
